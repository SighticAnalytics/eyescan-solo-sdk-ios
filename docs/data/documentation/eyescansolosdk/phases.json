{"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"When adding EyeScan Solo SDK to your app, the user experience has two parts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The views implemented by your app, also referred to as the “host app”, to introduce the scan and display the results."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The EyeScan Solo SDK flow, which is entirely handled by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticView"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"identifier":"eyescan-solo-sdk-overview-phases.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"An example implementation is available in the ","type":"text"},{"identifier":"https:\/\/github.com\/SighticAnalytics\/eyescan-solo-sdk-quickstart-app-ios","isActive":true,"type":"reference"},{"text":" project.","type":"text"}]},{"level":2,"type":"heading","text":"Alignment","anchor":"Alignment"},{"type":"paragraph","inlineContent":[{"text":"The alignment view helps the user position their face correctly in front of the device.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There is also a button to cancel the alignment and return control to the host app.","type":"text"}]},{"level":2,"type":"heading","text":"Scan","anchor":"Scan"},{"type":"paragraph","inlineContent":[{"text":"A moving dot is shown to the app user during the scan. The user should follow the dot with their eyes.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The scan will return to the alignment view if the user misaligns while doing the scan, for example by moving the device too far away from their face. A hint is provided on how to fix the misalignment. The scan restarts from the beginning when the user is correctly positioned. If the user fails to keep sufficiently aligned during the scan three times, control is returned back to the host app with a ","type":"text"},{"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticRecordingError","isActive":true,"type":"reference"},{"text":" result.","type":"text"}]},{"level":2,"type":"heading","text":"Analysis","anchor":"Analysis"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticView","isActive":true,"type":"reference"},{"text":" completion handler provides the host app with the recorded data as a ","type":"text"},{"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticRecording","isActive":true,"type":"reference"},{"text":" struct when the user has completed the scan.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The host app sends the recorded data to the Sightic Analytics server for analysis by calling ","type":"text"},{"code":"SighticRecording\/performInference()","type":"codeVoice"},{"text":". The data sent to the server contains device motions and features extracted from the face of the app user. The data does not contain a video stream that can be used to identify the user.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The app receives a ","type":"text"},{"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticInference","isActive":true,"type":"reference"},{"text":" with the scan result, or a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticError"},{"type":"text","text":" if an error occurs."}]}]}],"sections":[],"abstract":[{"type":"text","text":"A description of the EyeScan Solo SDK user interface flow."}],"identifier":{"url":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Phases","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK"]]},"variants":[{"paths":["\/documentation\/eyescansolosdk\/phases"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","metadata":{"modules":[{"name":"EyeScanSoloSDK"}],"role":"article","title":"Phases","roleHeading":"Article"},"seeAlsoSections":[{"title":"Essentials","generated":true,"anchor":"Essentials","identifiers":["doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Requirements","doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/APIKey","doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Integrating","doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Privacy"]}],"references":{"https://github.com/SighticAnalytics/eyescan-solo-sdk-quickstart-app-ios":{"titleInlineContent":[{"type":"text","text":"EyeScan Solo SDK Quickstart"}],"type":"link","url":"https:\/\/github.com\/SighticAnalytics\/eyescan-solo-sdk-quickstart-app-ios","identifier":"https:\/\/github.com\/SighticAnalytics\/eyescan-solo-sdk-quickstart-app-ios","title":"EyeScan Solo SDK Quickstart"},"doc://com.sightic.EyeScanSoloSDK/documentation/EyeScanSoloSDK/Integrating":{"url":"\/documentation\/eyescansolosdk\/integrating","title":"Integrating with Your App","identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Integrating","type":"topic","role":"article","kind":"article","abstract":[{"type":"text","text":"SighticView is the entry point to the EyeScan Solo SDK framework and presents alignment and scan views to the user."}]},"doc://com.sightic.EyeScanSoloSDK/documentation/EyeScanSoloSDK/SighticInference":{"type":"topic","identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticInference","abstract":[{"type":"text","text":"An EyeScan Solo SD