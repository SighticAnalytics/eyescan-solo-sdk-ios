{"seeAlsoSections":[{"identifiers":["doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Requirements","doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/APIKey","doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Integrating","doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Privacy"],"anchor":"Essentials","title":"Essentials","generated":true}],"hierarchy":{"paths":[["doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK"]]},"variants":[{"paths":["\/documentation\/eyescansolosdk\/phases"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"A description of the EyeScan Solo SDK user interface flow."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/Phases","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When adding EyeScan Solo SDK to your app, the user experience has two parts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The views implemented by your app, also referred to as the “host app”, to introduce the scan and display the results.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The EyeScan Solo SDK flow, which is entirely handled by ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticView","isActive":true},{"type":"text","text":"."}]}]}]},{"type":"paragraph","inlineContent":[{"identifier":"eyescan-solo-sdk-overview-phases.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"An example implementation is available in the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/SighticAnalytics\/eyescan-solo-sdk-quickstart-app-ios","isActive":true},{"type":"text","text":" project."}]},{"type":"heading","text":"Alignment","level":2,"anchor":"Alignment"},{"type":"paragraph","inlineContent":[{"text":"The alignment view helps the user position their face correctly in front of the device.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is also a button to cancel the alignment and return control to the host app."}]},{"type":"heading","text":"Scan","level":2,"anchor":"Scan"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A moving dot is shown to the app user during the scan. The user should follow the dot with their eyes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The scan will return to the alignment view if the user misaligns while doing the scan, for example by moving the device too far away from their face. A hint is provided on how to fix the misalignment. The scan restarts from the beginning when the user is correctly positioned. If the user fails to keep sufficiently aligned during the scan three times, control is returned back to the host app with a "},{"isActive":true,"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticRecordingError","type":"reference"},{"type":"text","text":" result."}]},{"type":"heading","text":"Analysis","level":2,"anchor":"Analysis"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticView","type":"reference","isActive":true},{"type":"text","text":" completion handler provides the host app with the recorded data as a "},{"type":"reference","identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticRecording","isActive":true},{"text":" struct when the user has completed the scan.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The host app sends the recorded data to the Sightic Analytics server for analysis by calling ","type":"text"},{"code":"SighticRecording\/performInference()","type":"codeVoice"},{"text":". The data sent to the server contains device motions and features extracted from the face of the app user. The data does not contain a video stream that can be used to identify the user.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The app receives a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticInference"},{"type":"text","text":" with the scan result, or a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticError"},{"type":"text","text":" if an error occurs."}],"type":"paragraph"}]}],"metadata":{"roleHeading":"Article","modules":[{"name":"EyeScanSoloSDK"}],"title":"Phases","role":"article"},"kind":"article","references":{"doc://com.sightic.EyeScanSoloSDK/documentation/EyeScanSoloSDK/SighticError":{"url":"\/documentation\/eyescansolosdk\/sighticerror","type":"topic","navigatorTitle":[{"kind":"identifier","text":"SighticError"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SighticError"}],"title":"SighticError","identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK\/SighticError","role":"symbol","abstract":[{"type":"text","text":"Error that occurs during the analysis of a scan by the Sightic Analytics backend."}]},"doc://com.sightic.EyeScanSoloSDK/documentation/EyeScanSoloSDK":{"kind":"symbol","identifier":"doc:\/\/com.sightic.EyeScanSoloSDK\/documentation\/EyeScanSoloSDK","role":"collection","abstract":[{"text":"Predict if a person may be impaired due to substance use.","type":"text"}],"type":"topic","url":"\/documentation\/eyescansolosdk","title":"EyeScanSoloSDK"},"https://github.com/SighticAnalytics/eyescan-solo-sdk-quickstart-app-ios":{"url":"https:\/\/github.com\/SighticAnalytics\/eyescan-solo